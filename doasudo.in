#!/bin/sh

# SPDX-License-Identifier: MIT
# See LICENSE.md. Part of doas-utils/doasudo.
#
# doasudo: translate sudo(8) calls to doas(1) with full option coverage,
# POSIX-safe argument parsing, and security hardening.
#
# Compatibility: Linux, OpenBSD, FreeBSD, NetBSD, DragonFly BSD, macOS
#
# ---
#
# SECURITY NOTE
#
# Untrusted data (arguments, environment variables) enters the shim and flows
# to doas, the editor, and the broker (if enabled). To prevent this data from
# triggering unintended privileged behavior, the shim enforces four
# input-handling rules:
#
# - Validate: Match inputs against an allowlist. Die on failure.
# - Normalize: Canonicalize once. Pass only canonical form downstream.
# - Frame: Pass runtime data via positional parameters or variables to prevent
#   shell re-parsing. Use safe bindings such as `sh -c '...' _ "$value"` or
#   `awk -v name="$value" '...'` after normalization.
# - Bound: Cap data size, enforce structure, and restrict character classes.
#   Reject overflows or malformed payloads.
#
# Beyond input handling, edit mode expands the threat surface to the filesystem
# with two attack families in scope. Symlink substitution: an attacker swaps a
# path component or the target with a symlink so the privileged write-back lands
# on the wrong file. Tmpfile substitution: an attacker replaces or alters the
# working copy during the edit session so unexpected content reaches the target.
#
# To enforce the input-handling rules and mitigate filesystem threats, the shim
# uses four strategies (tags match inline comments):
#
# - [boundary]: Establish execution boundaries. Resolve trusted binaries, parse
#   only allowed options, and enforce strict framing for the doas invocation and
#   the edit pipeline.
# - [path-trust]: Enforce path integrity. Reject symlinks and writable
#   components during traversal. Snapshot metadata and require a full
#   re-walk match before write-back.
# - [fd-anchor]: Pin operations to file descriptors. Anchor with O_CREAT|O_EXCL,
#   restrict reads/stats to open fds, and hold descriptors open (fd 3, fd 5)
#   across privileged moves.
# - [seal-verify]: Seal and verify workspace state. Lock permissions on
#   temporary directories, verify inodes, and check content digests
#   before the privileged write-back. Fail closed on mismatch.
#
# These strategies do not eliminate same-UID threats for the lifetime of the
# editor session (real sudoedit has identical exposure). An optional broker
# keeps the working copy and editor policy outside the invoking user's tree, and
# returns edited bytes through a framed protocol; privileged write-back is
# unchanged. See the edit-broker's SECURITY NOTE for more details.

set -eu
IFS=$(printf ' \t\n_'); IFS="${IFS%_}"

_VERSION='@VERSION@'

# Baked in at build time; runtime PATH cannot influence it. Shim must be
# installed in a root-owned directory (e.g. /usr/local/bin).
_SHIM_UTILS_PATH='@SHIM_UTILS@'
_SHIM_UTILS_METADATA='@UTILS_METADATA@'
# @EDIT_BROKER_METADATA@

_NL=$(printf '\n_'); _NL="${_NL%_}"
_TAB=$(printf '\t')

# Empty defaults; edit-mode.sh assigns non-empty values in EDIT_MODE=1 builds.
_EDIT_HELP_USAGE=
_EDIT_HELP_INVOCATION_NOTE=
_EDIT_HELP_OPTION=
_EDIT_HELP_NOTES=

# ---- Help --------------------------------------------------------------------------------

help() {
  case "${0##*/}" in
    sudoedit | editas)
      _edit_mode_help
      ;;
    *)
      cat <<EOF
Usage:
  sudo (-i | -s) [-n] [-u <user>] [<command> [--] [<args>...]]
  sudo [-ins] [-u <user>] <command> [--] [<args>...]
  sudo [-h | -V | -l | -v | -k | -K]
${_EDIT_HELP_USAGE:+${_EDIT_HELP_USAGE}${_NL}}
Execute a command as another user using doas(1).
${_EDIT_HELP_INVOCATION_NOTE:+${_EDIT_HELP_INVOCATION_NOTE}${_NL}}
Translated options:
  -u <user>, --user      Run as <user> (username only; #UID not supported)
  -H, --set-home         Set HOME to target user's passwd entry
  -i, --login            Run target user's login shell
  -s, --shell            Run \$SHELL (or invoking user's shell)
  -n, --non-interactive  Fail rather than prompt
${_EDIT_HELP_OPTION:+${_EDIT_HELP_OPTION}${_NL}}
Credential-cache flags (doas has no cache; these approximate the intent):
  -K, --remove-timestamp
    Run 'doas -L' to clear persisted auth, then exit.
    May not be combined with a command or other option.
  -k, --reset-timestamp
    Without a command: run 'doas -L', then exit.
    With a command: no-op; the command runs normally.
    In real sudo, -k with a command forces re-authentication and
    suppresses cache update. doas has no cache, so neither applies;
    the command runs as if -k were absent.
  -v, --validate
    Not supported; exits with an error. doas has no credential
    cache or policy-query primitive, so -v has no faithful
    implementation. Scripts using 'sudo -v' or 'sudo -Nnv' as an
    auth gate must test the specific command they intend to run.

Warned and ignored:
  -E, --preserve-env, --preserve-env=LIST
    Not supported. Add 'keepenv' to /etc/doas.conf instead.
  -A, --askpass
    Not supported; doas will prompt on /dev/tty.
  -S, --stdin
    Not supported; doas reads passwords from /dev/tty, not stdin.
  -D <dir>, --chdir
    Not supported; command runs in the current directory.
  -R <dir>, --chroot
    Not supported; command runs without a chroot. (Deprecated in sudo.)

Silently ignored:
  -B, -P
  -p/--prompt, -C/--close-from, -T/--command-timeout
  -U/--other-user
    Only meaningful with -l, which exits with a "not supported"
    notice; -U never takes effect.
  -N, --no-update
    In real sudo, uses cached credentials without updating them.
    doas has no cache; no-op (same effect as -k with a command).
  -r/--role, -t/--type  (SELinux; not supported by doas)

Fatal:
  -g, --group            doas cannot switch the primary group of the
                         target process; use newgrp(1) or sg(1) instead
  -b, --background       see NOTES

NOTES

  -b/--background
    doas authenticates via /dev/tty. A backgrounded process needing a
    password hangs invisibly. Add a 'nopass' rule to doas.conf and
    use & directly instead.

  -h
    Always means --help. Bundled -hX re-injects -X; since -h exits
    immediately, those flags are never processed. '-h hostname' is
    indistinguishable from bare -h. --host requires plugin support
    that doas does not provide.

  -i/-s with a command
    Arguments are shell-escaped per sudo(8): every character except
    alphanumerics, underscores, hyphens, and dollar signs is
    backslash-prefixed, then space-joined and passed via -c.
    Builtins, variables, and compound commands work because safe
    characters pass through unquoted.

  VAR=value assignments
    Discarded with a warning (hard error in edit mode).
    Add 'keepenv' to /etc/doas.conf to pass variables through.
${_EDIT_HELP_NOTES:+${_EDIT_HELP_NOTES}${_NL}}
  #UID syntax
    Not supported. The shim exits with an error; use the username
    instead.

  SUDO_COMMAND
    Not set. doas provides no equivalent. PAM modules or audit
    scripts that check it will see an unset variable.

See sudo(8) and doas(1) for more information.
EOF
      ;;
  esac
}

_edit_mode_help() { die "edit mode is not built into this doasudo"; }

# ---- Helpers -----------------------------------------------------------------------------

warn()  { printf 'sudo: warning: %s\n' "$*" >&2; }
die()   { printf 'sudo: %s\n' "$*" >&2; exit 1; }
fatal() { die "$*"; }  # "$_SHIM_UTILS_PATH" (shim-utils.sh) calls this

[ -r "$_SHIM_UTILS_PATH" ] || die "missing ${_SHIM_UTILS_PATH} (incomplete installation)"
# shellcheck disable=SC1091 source=lib/shim-utils.sh
. "$_SHIM_UTILS_PATH"

# doas has no version flag; report without probing.
_print_version() {
  printf 'doasudo %s / doas (version unknown)\n' "$_VERSION"
}

_print_list_notice() {
  # sudo(8) -l prints to stdout; shim prints to stderr to match other
  # "not supported" messages.
  printf 'sudo: listing is not supported by doas.\nReview /etc/doas.conf for permitted rules.\n' >&2
}

# Sets $_user from $1. Dies on empty or #UID argument; numeric UIDs are
# rejected for portability across doas implementations.
# $_user is never string-split by the shim; it is always passed quoted.
# doas is the authoritative validator.
_set_user() {
  case "$1" in
    \#*) die "-u/--user: #UID syntax is not supported; use the username instead" ;;
  esac
  _user="$1"
  [ -n "$_user" ] || die "-u/--user requires a non-empty argument"
}

# Looks up a single colon-separated field from the passwd database for
# <user> (default: root) and prints it to stdout.
# <field> is a passwd field number (positive integer).
# Returns 1 with no output when the user is not found; the caller supplies the
# diagnostic so each call site can name the context.
#
# Prefers getent(1) when available, then id -P (FreeBSD/DragonFly BSD/macOS)
# with normalization to match getent, and falls back to awk on /etc/passwd.
_get_passwd_field() {
  _gpf_u="${1:-root}"
  # Guard the field specifier before interpolating it into the awk program.
  # Accepted values are positive integers from 1 to 7 (field number).
  # Rejecting anything else closes the awk injection surface.
  case "$2" in
    [1-7]) ;;
    *) die "_get_passwd_field: invalid field specifier: '${2}'" ;;
  esac
  _gpf_field=$2

  _gpf_entry=
  [ -n "$_GETENT" ] && {
    _gpf_entry=$(LC_ALL=C "$_GETENT" passwd -- "$_gpf_u" 2>/dev/null) || _gpf_entry=
  }
  [ -z "$_gpf_entry" ] && [ -n "${_ID:-}" ] && {
    _gpf_aux="NR==1 && NF==10 { printf \"%s:%s:%s:%s:%s:%s:%s\", \$1,\$2,\$3,\$4,\$8,\$9,\$10 }"
    _gpf_entry=$(LC_ALL=C "$_ID" -P -- "$_gpf_u" 2>/dev/null | "$_AWK" -F: "$_gpf_aux")
  }
  [ -z "$_gpf_entry" ] && {
    _gpf_aux="BEGIN{u=ENVIRON[\"u\"]} \$1==u {print; exit}"
    _gpf_entry=$(LC_ALL=C u="$_gpf_u" "$_AWK" -F: "$_gpf_aux" /etc/passwd 2>/dev/null)
  }
  [ -n "$_gpf_entry" ] || return 1

  printf '%s' "$_gpf_entry" | "$_AWK" -F: "{print \$${_gpf_field}; exit}"
}

# Returns the home directory for a user (default: root).
# Dies if the user is missing, the path is not absolute, or the path
# contains an embedded newline. A relative path silently lands in an
# attacker-chosen directory; a newline corrupts environment strings and
# shell -c targets at every call site.
_user_home() {
  _uh_u="${1:-root}"
  _uh_home=$(_get_passwd_field "$_uh_u" 6) || die "_user_home: user '${_uh_u}' not found"
  case "${_uh_home:-}" in
    /*) ;;
    *) die "invalid or missing home directory for user '${_uh_u}': '${_uh_home:-<empty>}'" ;;
  esac
  case "$_uh_home" in
    *"${_NL}"*) die "home directory for user '${_uh_u}' contains a newline; cannot process safely" ;;
  esac
  printf '%s' "$_uh_home"
}

# Returns the login shell for a user (default: root).
# Dies if the user is missing or the shell is not an absolute path.
# A compromised or malformed passwd entry must not become an exec target.
_user_shell() {
  _us_u="${1:-root}"
  _us_sh=$(_get_passwd_field "$_us_u" 7) || die "_user_shell: user '${_us_u}' not found"
  case "${_us_sh:-}" in
    /*) printf '%s' "$_us_sh" ;;
    *) die "invalid or missing shell for user '${_us_u}': '${_us_sh:-<empty>}'" ;;
  esac
}

# Execs doas, setting SUDO_* for the target. Reads $_user.
# All dispatch paths converge here to keep SUDO_* assignment in one place.
#
# $_DOAS and /usr/bin/env are absolute paths; a bare name would let a
# keepenv-poisoned PATH substitute a trojan.
#
# if/else rather than ${_user:+-u "$_user"}: the shim makes no assumptions
# about $_user's contents (validation is deferred to doas), so the two-token
# expansion must be safe for any value, and explicit branches are the correct
# POSIX sh solution. Update both branches when adding doas flags and run
# doas-flags-parity_test.sh.
#
# -- after /usr/bin/env prevents a -i in "$@" from clearing the environment.
# Call sites must not pass --: it lands between the VAR=VALUE pairs and the
# command, causing env to exec '--' and exit 127.
#
# SUDO_PS1: sudo(8) passes SUDO_PS1 to the target as PS1.
# ${SUDO_PS1+PS1="$SUDO_PS1"} expands only when SUDO_PS1 is set (including
# empty), preserving the set-vs-unset distinction. The inner double-quotes
# prevent field splitting per POSIX 2.6.2: field splitting is not performed on
# the results of a parameter expansion that occurs inside double-quotes,
# so values with spaces remain a single token passed to env(1):
#
#   SUDO_PS1='foo bar' sh -c \
#     '/usr/bin/env -- ${SUDO_PS1+PS1="$SUDO_PS1"} printenv PS1'
#   -> foo bar  # one env argument, not two
_doas_exec() {
  _de_home=
  if [ -n "${flag_H:-}" ]; then
    _de_home=$(_user_home "${_user:-root}") || exit 1
  fi
  if [ -n "$_user" ]; then
    exec "$_DOAS" ${flag_n:+"-n"} -u "$_user" -- \
      /usr/bin/env -- \
        ${flag_H:+"HOME=$_de_home"} \
        SUDO_UID="$SUDO_UID" SUDO_GID="$SUDO_GID" SUDO_USER="$SUDO_USER" \
        SUDO_HOME="$SUDO_HOME" SUDO_TTY="$SUDO_TTY" \
        ${SUDO_PS1+PS1="$SUDO_PS1"} \
      "$@"
  else
    exec "$_DOAS" ${flag_n:+"-n"} -- \
      /usr/bin/env -- \
        ${flag_H:+"HOME=$_de_home"} \
        SUDO_UID="$SUDO_UID" SUDO_GID="$SUDO_GID" SUDO_USER="$SUDO_USER" \
        SUDO_HOME="$SUDO_HOME" SUDO_TTY="$SUDO_TTY" \
        ${SUDO_PS1+PS1="$SUDO_PS1"} \
      "$@"
  fi
}

# Escapes a token by backslash-prefixing every character outside the safe
# set. Loops via parameter expansion; no subprocesses. $() strips trailing
# newlines; callers must reject arguments ending with one.
#
# $1: string to escape.
# $2: pass 'shell_mode' when the string is a shell -c command argument,
#     so that $ passes through unescaped and expands in the child shell.
#     Omit (or pass empty) for filesystem paths embedded in a -c string,
#     where $ must be escaped. Defaulting to the restrictive behavior means
#     a forgotten flag escapes $ rather than silently permitting expansion
#     in an unintended context.
_escape_arg() {
  LC_ALL=C
  _ea_result="" _ea_rest="$1" _ea_shell_mode="${2:-}"
  while [ -n "$_ea_rest" ]; do
    _ea_ch="${_ea_rest%"${_ea_rest#?}"}"   # first character
    _ea_rest="${_ea_rest#?}"               # remainder
    case "$_ea_ch" in
      [-A-Za-z0-9_])
        _ea_result="${_ea_result}${_ea_ch}" ;;
      '$')
        if [ -n "$_ea_shell_mode" ]; then
          _ea_result="${_ea_result}$"
        else
          _ea_result="${_ea_result}\\$"
        fi ;;
      *)
        _ea_result="${_ea_result}\\${_ea_ch}" ;;
    esac
  done
  printf '%s' "$_ea_result"
}

# Escapes and space-joins all arguments into a single shell -c string.
# Used by -i and -s dispatch.
#
# An empty argument escapes to nothing, which the receiving shell silently
# ignores, producing a different command. A trailing newline would be silently
# stripped by the $(_escape_arg ...) call, making it undetectable afterward;
# both are rejected before _escape_arg is called.
_join_args() {
  _ja_result=""
  for _ja_a in "$@"; do
    case "$_ja_a" in
      '') die "-i/-s: empty string argument cannot be passed safely via shell -c" ;;
      *"${_NL}"*) die "-i/-s: argument contains a newline and cannot be passed safely via shell -c" ;;
    esac
    _ja_escaped=$(_escape_arg "$_ja_a" shell_mode)
    _ja_result="${_ja_result:+$_ja_result }$_ja_escaped"
  done
  printf '%s' "$_ja_result"
}

# Opens a login shell; with arguments, joins them into a -c string via _join_args.
#
# sudo(8) changes to the target user's home directory. For interactive
# sessions doas sets HOME, so .profile/.bash_profile handle the cd
# automatically. With a command, many shells skip the automatic chdir,
# so the home directory is prepended as 'cd -- <home> &&'. The path is
# escaped without shell_mode so $ does not expand in a filesystem path
# (contrast _join_args, where shell_mode is correct because $ expansion
# in the target shell is the intended behavior).
# Newline and absolute-path checks are enforced by _user_home.
_exec_login_shell() {
  _els_shell=$(_user_shell "${_user:-root}")
  if [ $# -eq 0 ]; then
    _doas_exec "$_els_shell" -l
  else
    _els_raw_home=$(_user_home "${_user:-root}")
    _els_home=$(_escape_arg "$_els_raw_home")
    _els_cmd=$(_join_args "$@")
    _doas_exec "$_els_shell" -l -c "cd -- ${_els_home} && ${_els_cmd}"
  fi
}

_run_edit_mode() { _edit_mode_help; }
# @EDIT_MODE_BLOCK@

# ---- Pre-parse short-circuit -------------------------------------------------------------
#
# Handles --help and --version before the doas check so they work without
# doas installed, and before 'set -- -e "$@"' so 'sudoedit --help' sees
# $1=--help rather than $1=-e.

case "${1:-}" in
  -h | --help)    help; exit 0 ;;
  -V | --version) _print_version; exit 0 ;;
esac

# ---- Symlink / alias invocation ----------------------------------------------------------
#
# sudoedit and editas prepend -e; _edit_cmd names the invoking command for
# edit-mode diagnostics.
# One parser handles all three names; mutual-exclusion checks catch
# dangerous combinations (-e with -i or -s).
# The parser accepts -K and -v for sudoedit even though they are absent
# from its synopsis. Both are safe: -K exits before any command runs; -v
# exits with an error.
case "${0##*/}" in
  sudoedit | editas) set -- -e "$@" ;;
esac

# ---- Locate and verify doas --------------------------------------------------------------
#
# _resolve_bin searches _SUDO_SHIM_PATH, baked in at install time from a
# root-controlled path. User-controlled PATH cannot influence this lookup.
# The [ -u ] check catches a dropped setuid bit, not PATH substitution.
_DOAS=$(_resolve_bin doas) || die 'doas not found in SHIM_PATH'
[ -u "$_DOAS" ] || die "doas at '${_DOAS}' does not have the setuid bit set"

if [ $# -eq 0 ]; then
  help >&2; exit 1
fi

# ---- Argument parsing --------------------------------------------------------------------
#
# Long options match directly, including --opt=val forms. No generic
# --foo=bar -> --foo bar normalizer: that approach moves unrecognized
# option values into the command position.
#
# Short bundles (e.g. -nsu root) unpack character by character via
# parameter expansion: _token strips the '-', _ch takes the first
# char, _tail the rest. No subprocesses. Value-taking shorts consume
# from _tail when bundled (-uroot) or from the next positional (-u root).

# Flags are stored as '1'; ${flag_n:+"-n"} in _doas_exec derives the literal
# string at each call site.
flag_i=; flag_s=; flag_n=; flag_e=; flag_H=; flag_k=; flag_K=; flag_l=; flag_v=; flag_env_assign=

_user=

_mark_non_k_option() {
  [ -z "${flag_K:-}" ] || die "-K/--remove-timestamp may not be combined with a command or other options"
  _seen_non_k_option=1
}

_mark_k_option() {
  [ -z "${_seen_non_k_option:-}" ] || die "-K/--remove-timestamp may not be combined with a command or other options"
  flag_K=1
}

while [ $# -gt 0 ]; do
  case "$1" in

    # ---- End of options ------------------------------------------------------------------
    --)
      shift; break ;;

    # ---- Long options --------------------------------------------------------------------
    --*)
      case "$1" in
        --remove-timestamp) _mark_k_option ;;
        *)                  _mark_non_k_option ;;
      esac
      case "$1" in
        --login)            flag_i=1 ;;
        --shell)            flag_s=1 ;;
        --non-interactive)  flag_n=1 ;;
        --edit)             flag_e=1 ;;
        --set-home)         flag_H=1 ;;

        --user=*)           _set_user "${1#--user=}" ;;
        --user)
          [ $# -ge 2 ] || die "--user requires an argument"
          _set_user "$2"; shift ;;

        --preserve-env=*)
          warn "--preserve-env=LIST: not supported; add 'keepenv' to /etc/doas.conf instead" ;;
        --preserve-env)
          warn "--preserve-env: not supported; add 'keepenv' to /etc/doas.conf instead" ;;

        --background)
          die "-b/--background is not supported; see 'sudo --help' for rationale" ;;

        --group=* | --group)
          die "--group is not supported; doas cannot set the target process group; use newgrp(1) or sg(1) instead" ;;

        # -k, -K, and -v defer to the post-parse block, which sees the full
        # command line and enforces -K's "no command or other option" rule.
        --reset-timestamp)  flag_k=1 ;;
        --remove-timestamp) ;;

        --validate)         flag_v=1 ;;

        --help)             help; exit 0 ;;
        --version)          _print_version; exit 0 ;;
        # sudo(8) exits 0 when listing is permitted, 1 otherwise. Without
        # policy to consult, exit 1 when a command follows (conservative),
        # 0 otherwise. $# includes --list itself, so > 1 means a command.
        --list)             flag_l=1 ;;

        --host=*)
          warn "--host is not supported; ignoring host '${1#--host=}'" ;;
        --host)
          [ $# -ge 2 ] || die "--host requires an argument"
          warn "--host is not supported; ignoring host '$2'"
          shift ;;

        # --chdir: no doas equivalent. Warn to avoid silently misleading
        # callers that rely on a specific working directory.
        --chdir=*)
          warn "--chdir: not supported by doas; command will run in the current directory" ;;
        --chdir)
          [ $# -ge 2 ] || die "--chdir requires an argument"
          warn "--chdir: not supported by doas; command will run in the current directory"
          shift ;;

        # --chroot: no doas equivalent. Deprecated in sudo(8). Warn to
        # avoid silently misleading callers.
        --chroot=*)
          warn "--chroot: not supported by doas; command will run without a chroot" ;;
        --chroot)
          [ $# -ge 2 ] || die "--chroot requires an argument"
          warn "--chroot: not supported by doas; command will run without a chroot"
          shift ;;

        # Value-carrying options with no doas equivalent. =* arms consume
        # the value inline; bare arms shift it off to keep it out of the
        # command position.
        --prompt=* | --close-from=* | \
        --command-timeout=* | --role=* | --type=* | --other-user=*) ;;
        --prompt | --close-from | \
        --command-timeout | --role | --type | --other-user)
          [ $# -ge 2 ] || die "$1 requires an argument"
          shift ;;

        # --askpass: caller expects non-TTY auth (e.g. a graphical helper).
        # Silently ignoring this causes doas to prompt on /dev/tty, which
        # may hang in the caller's context.
        --askpass)
          warn "--askpass: not supported; doas will prompt on /dev/tty" ;;

        --bell | --preserve-groups) ;;  # no doas equivalent; silently ignored

        --stdin)
          warn "--stdin: not supported; doas reads passwords from /dev/tty, not stdin" ;;

        # --no-update: sudo(8) uses cached creds without updating on success.
        # doas has no cache; no-op.
        --no-update) ;;

        # Unknown long options are fatal, matching sudo(8)'s behavior.
        # Known-but-unsupported options have explicit warn arms above; only
        # unrecognized options reach here. Dying rather than warning prevents
        # a future sudo(8) flag with security or authorization semantics from
        # being silently dropped while the command still executes.
        *)
          die "unknown option '$1'" ;;
      esac
      shift ;;

    # ---- Short options (including bundles like -nsu) -------------------------------------
    -?*)
      _token="${1#-}"
      _ch="${_token%"${_token#?}"}"
      _tail="${_token#?}"
      shift

      # Value-taking options push the tail back as the next positional
      # so the case below consumes it as the value. Others re-inject
      # the tail as a new bundle (-${_tail}) for the next iteration.
      # -h exits immediately; re-injecting its tail is harmless.
      case "$_ch" in
        u | p | C | D | R | T | U | r | t)
          [ -n "$_tail" ] && set -- "$_tail" "$@" ;;
        *)
          [ -n "$_tail" ] && set -- "-${_tail}" "$@" ;;
      esac

      case "$_ch" in
        K) _mark_k_option ;;
        *) _mark_non_k_option ;;
      esac

      case "$_ch" in
        i) flag_i=1 ;;
        s) flag_s=1 ;;
        n) flag_n=1 ;;
        e) flag_e=1 ;;
        H) flag_H=1 ;;
        u)
          [ $# -ge 1 ] || die "-u requires an argument"
          _set_user "$1"; shift ;;
        k) flag_k=1 ;;
        K) ;;
        # -v/--validate: deferred to post-parse like -k/-K so accompanying
        # flags (-u, -n) are visible at dispatch.
        v) flag_v=1 ;;
        # -h always means --help. Bundled tail was re-injected above; since
        # we exit here it is never reached.
        h) help; exit 0 ;;
        V) _print_version; exit 0 ;;
        # sudo(8) exits 0 when listing is permitted, 1 otherwise. Without
        # policy to consult, exit 1 when a command follows (conservative),
        # 0 otherwise. $1 was already shifted, so > 0 means a command.
        l) flag_l=1 ;;
        g) die "-g/--group is not supported; doas cannot set the target process group; use newgrp(1) or sg(1) instead" ;;
        b) die "-b/--background is not supported; see 'sudo --help' for rationale" ;;
        A) warn "-A/--askpass: not supported; doas will prompt on /dev/tty" ;;
        B | P) ;;  # same: --bell, --preserve-groups
        S) warn "-S/--stdin: not supported; doas reads passwords from /dev/tty, not stdin" ;;
        # -N/--no-update: sudo(8) uses cached creds without updating on
        # success. doas has no cache; no-op.
        N) ;;
        E) warn "-E/--preserve-env: not supported; add 'keepenv' to /etc/doas.conf instead" ;;
        p | C | T | U | r | t)
          [ $# -ge 1 ] || die "-${_ch} requires an argument"
          shift ;;
        R)
          [ $# -ge 1 ] || die "-R requires an argument"
          warn "-R/--chroot: not supported by doas; command will run without a chroot"
          shift ;;
        D)
          [ $# -ge 1 ] || die "-D requires an argument"
          warn "-D/--chdir: not supported by doas; command will run in the current directory"
          shift ;;
        *)
          die "unknown option '-${_ch}'" ;;
      esac
      continue ;;

    # ---- VAR=value environment assignments -----------------------------------------------
    # sudo(8) allows VAR=value before the command. Tokens after -- never
    # enter the loop, so 'sudo -- VAR=cmd' passes VAR=cmd as a command
    # name. doas rejects env assignments; flag_env_assign is set so edit
    # mode can treat them as a hard error.
    *=*)
      _mark_non_k_option
      flag_env_assign=1
      warn "VAR=value assignments are not supported; ignoring '$1'"
      shift; continue ;;

    # ---- First non-option token: start of command ----------------------------------------
    *)
      break ;;
  esac
done

# ---- Post-parse validation and deferred flag dispatch ------------------------------------

if [ "${flag_i:-}" ] && [ "${flag_s:-}" ]; then
  die "you may not specify both '-i' and '-s'"
fi


# sudo(8): "you may not specify environment variables in edit mode."
if [ "${flag_e:-}" ] && [ "${flag_env_assign:-}" ]; then
  die "you may not specify environment variables in edit mode"
fi

# Runs 'doas -L' and exits. $1 names the flag for diagnostics.
# doas -L exits non-zero when no token exists or the flag is unsupported;
# the two cases are indistinguishable. Exit non-zero so the caller knows
# the cache may not have been cleared.
_invalidate_cache() {
  if "$_DOAS" -L ; then
    exit 0
  fi
  warn "${1}: 'doas -L' failed; the credential cache may not have been cleared"
  exit 1
}

# sudo(8): "-K may not be combined with a command or other option."
if [ "${flag_K:-}" ]; then
  if [ $# -gt 0 ]; then
    die "-K/--remove-timestamp may not be combined with a command or other options"
  fi
  _invalidate_cache -K
fi

if [ "${flag_l:-}" ]; then
  _print_list_notice
  [ $# -gt 0 ] && exit 1
  exit 0
fi

# -k without a command clears persisted doas auth and exits.
# With a command, it is a no-op: sudo(8) forces re-auth and suppresses
# cache update, but doas has no cache, so neither applies.
if {
  [ "${flag_k:-}" ] && [ $# -eq 0 ] &&
  [ -z "${flag_i:-}" ] && [ -z "${flag_s:-}" ] && [ -z "${flag_e:-}" ]
}; then
  _invalidate_cache -k
fi

# -v authenticates and updates sudo's credential cache, confirming the
# user has some privilege. doas has no cache and no policy-query primitive;
# a per-command probe (e.g. doas true) is not equivalent: a user permitted
# only /usr/sbin/service fails doas true, producing a false negative. Die
# so callers discover the gap rather than rely on a wrong exit 0.
if [ "${flag_v:-}" ]; then
  die "-v/--validate is not supported: doas has no credential cache or policy-query primitive"
fi

# ---- Export SUDO_* variables -------------------------------------------------------------

# keepenv can poison PATH, so we resolve id to an absolute path.
_ID=$(_resolve_bin id) || die 'id not found in SHIM_PATH'

# A poisoned awk could return an attacker-chosen shell exec'd as the target.
_AWK=$(_resolve_bin awk) || die 'awk not found in SHIM_PATH'

# Optional: absent on BSD and macOS.
_GETENT=$(_resolve_bin getent optional)

# Optional: absent on some minimal systems; SUDO_TTY is set to '' if missing.
_TTY=$(_resolve_bin tty optional)

# Real (not effective) IDs; -r is correct even though a shell script
# cannot be setuid.
export SUDO_GID;  SUDO_GID=$("$_ID" -rg)   || die "id -rg failed"
export SUDO_UID;  SUDO_UID=$("$_ID" -ru)   || die "id -ru failed"
export SUDO_USER; SUDO_USER=$("$_ID" -run) || die "id -run failed"

# SUDO_HOME comes from the passwd database, not $HOME. $HOME is
# user-controlled; downstream PAM modules or audit scripts must not
# use it for path construction or access decisions.
export SUDO_HOME; SUDO_HOME=$(_user_home "$SUDO_USER") || exit 1

# SUDO_TTY is set only when a terminal is present; empty string otherwise.
# _is_dev_path rejects non-/dev paths from tty(1): a compromised binary could
# return a regular file or named pipe, creating an unintended channel if edit
# mode opened it for read/write.
export SUDO_TTY
if [ -n "$_TTY" ]; then
  SUDO_TTY=$("$_TTY" 2>/dev/null) || SUDO_TTY=
  _is_dev_path "$SUDO_TTY" || SUDO_TTY=
else
  SUDO_TTY=
fi

# SUDO_COMMAND is omitted: no portable approach produces a consistent
# value across the different dispatch paths.

# ---- Edit mode ---------------------------------------------------------------------------

if [ "${flag_e:-}" ]; then
  _run_edit_mode "$@"
fi

# ---- Dispatch ----------------------------------------------------------------------------

if [ -z "${flag_e:-}" ]; then
  # VAR=value tokens stripped by the parser cannot reach here via normal
  # dispatch; tokens after -- can. Real sudo would exec "VAR=value" and
  # fail with "command not found"; reject explicitly for a clearer diagnostic.
  case "${1:-}" in
    *=*) die "cannot use a variable assignment as a command name: '$1'" ;;
  esac

  if [ "${flag_i:-}" ]; then
    _exec_login_shell "$@"
  elif [ "${flag_s:-}" ]; then
    # -s uses the invoking user's shell, not the target's ($SHELL first,
    # then passwd). Contrast -i, which uses the target's login shell.
    # No newline check: $_shell is a quoted argument to _doas_exec; a
    # newline causes doas to reject the path rather than silently misbehave.
    _shell="${SHELL:-$(_user_shell "$SUDO_USER")}"
    case "$_shell" in /*) ;; *) die "invalid shell in \$SHELL: '${_shell}'" ;; esac
    if [ $# -eq 0 ]; then
      _doas_exec "$_shell"
    else
      _cmd=$(_join_args "$@")
      _doas_exec "$_shell" -c "$_cmd"
    fi
  elif [ $# -eq 0 ]; then
    die "no command specified"
  else
    # -- was consumed by the parser; _doas_exec must never receive a bare --.
    _doas_exec "$@"
  fi
fi
